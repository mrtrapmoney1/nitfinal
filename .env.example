# Resend (email — required for contact and classes forms)
RESEND_API_KEY=re_xxxxxxxxxxxx

# Google Analytics 4 (safe to expose — measurement ID only)
NEXT_PUBLIC_GA4_MEASUREMENT_ID=G-XXXXXXXXXX

# Google Maps Embed (restrict to nebnit.com in Google Cloud Console)
NEXT_PUBLIC_MAPS_EMBED_KEY=AIza...

# Google Search Console (service account JSON as single line — server only)
GOOGLE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"..."}

# Google PageSpeed Insights (server only)
GOOGLE_PSI_API_KEY=AIza...

# Google Custom Search (optional — OG image sourcing at build time)
GOOGLE_CSE_API_KEY=AIza...
GOOGLE_CSE_CX=xxxxxxxxxxxxxxx:xxxxxxxxxxx

# Site URL
NEXT_PUBLIC_SITE_URL=https://nebnit.com
